{
  "name": "kitokocss",
  "version": "2.0.0",
  "description": "Framework CSS moderne, modulaire et révolutionnaire basé sur l'écosystème Kitoko.",
  "private": true,
  "author": "MOLENGO MALANDA FORDI",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "npm run build",
    "clean": "rimraf dist packages/*/dist",
    "sass:build": "sass scss/kitoko.scss dist/css/kitoko.css --no-source-map",
    "sass:minify": "cleancss -o dist/css/kitoko.min.css dist/css/kitoko.css",
    "js:minify": "terser js/kitoko.js -o dist/js/kitoko.min.js --compress --mangle",
    "build": "npm run clean && npm run sass:build && npm run sass:minify && npm run js:minify",
    "watch": "sass scss/kitoko.scss dist/css/kitoko.css --watch",
    "cli:dev": "ts-node packages/kitoko-cli/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "clean-css-cli": "^5.6.3",
    "copyfiles": "^2.4.1",
    "rimraf": "^5.0.0",
    "sass": "^1.70.0",
    "terser": "^5.27.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}